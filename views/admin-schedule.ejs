<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule" class="active">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/notifications/send">Push Notif</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/users/premium">Manage Premium</a>
        <a href="/admin/leaderboard-xp">Leaderboard XP</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <section class="hero card">
      <h1>Schedule Manager</h1>
      <p class="muted">Atur jadwal rilis/anime dari Senin sampai Minggu.</p>
    </section>

    <% if (created) { %><p class="alert ok">Jadwal berhasil ditambahkan.</p><% } %>
    <% if (deleted) { %><p class="alert ok">Jadwal berhasil dihapus.</p><% } %>
    <% if (deletedAll) { %><p class="alert ok">Semua daftar jadwal berhasil dihapus.</p><% } %>
    <% if (syncDone) { %>
      <p class="alert ok">
        Auto-sync Otakudesu selesai.
        Page: <%= syncStats.pageStart %>-<%= syncStats.pageEnd %> |
        Scraped: <%= syncStats.scraped %> |
        Matched: <%= syncStats.matched %> |
        Inserted: <%= syncStats.inserted %> |
        Updated: <%= syncStats.updated %> |
        Skipped: <%= syncStats.skipped %>
      </p>
    <% } %>
    <% if (previewReady) { %><p class="alert ok">Preview sync sudah dibuat. Cek data di bawah lalu klik Apply jika setuju.</p><% } %>
    <% if (syncError) { %><p class="alert"><%= syncError %></p><% } %>
    <% if (error) { %><p class="alert"><%= error %></p><% } %>

    <% if (syncPreview) { %>
      <section class="card">
        <div class="section-head">
          <h3>Preview Auto Sync Otakudesu</h3>
          <div class="inline-actions">
            <form method="post" action="/admin/schedule/auto-sync-otakudesu/apply" onsubmit="return confirm('Apply sync jadwal dari preview ini?')">
              <button type="submit" class="btn">Apply Sync</button>
            </form>
            <a class="btn ghost" href="/admin/schedule?clear_preview=1">Discard Preview</a>
          </div>
        </div>
        <p class="muted">
          Page <%= syncPreview.pageFrom %>-<%= syncPreview.pageTo %> |
          Scraped: <%= syncPreview.scrapedCount %> |
          Matched: <%= syncPreview.matchedCount %> |
          Unmatched: <%= syncPreview.unmatchedCount %> |
          Insert: <%= (syncPreview.actionCounts && syncPreview.actionCounts.insert) || 0 %> |
          Update: <%= (syncPreview.actionCounts && syncPreview.actionCounts.update) || 0 %> |
          Skip: <%= (syncPreview.actionCounts && syncPreview.actionCounts.skip) || 0 %>
        </p>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Action</th>
                <th>Hari Baru</th>
                <th>Hari Saat Ini</th>
                <th>Series</th>
                <th>Slug Otakudesu</th>
                <th>Page</th>
              </tr>
            </thead>
            <tbody>
              <% (syncPreview.previewRows || []).forEach((r) => { %>
                <tr>
                  <td class="mono"><%= r.action %></td>
                  <td><%= r.day_of_week %></td>
                  <td><%= (r.current_days || []).length ? r.current_days.join(', ') : '-' %></td>
                  <td>
                    <a href="/admin/series/<%= r.series_id %>"><%= r.title || '-' %></a>
                    <span class="muted mono">(#<%= r.series_id %> / <%= r.series_slug_snapshot %>)</span>
                  </td>
                  <td class="mono"><%= r.source_slug %></td>
                  <td><%= r.source_page %></td>
                </tr>
              <% }); %>
              <% if (!(syncPreview.previewRows || []).length) { %>
                <tr><td colspan="6" class="muted">Tidak ada data match untuk di-sync.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if ((syncPreview.unmatchedRows || []).length) { %>
          <details style="margin-top:12px;">
            <summary class="mono">Show Unmatched Slug (<%= syncPreview.unmatchedRows.length %>)</summary>
            <div class="table-wrap" style="margin-top:8px;">
              <table>
                <thead>
                  <tr>
                    <th>Slug Otakudesu</th>
                    <th>Hari</th>
                    <th>Page</th>
                  </tr>
                </thead>
                <tbody>
                  <% syncPreview.unmatchedRows.forEach((u) => { %>
                    <tr>
                      <td class="mono"><%= u.slug %></td>
                      <td><%= u.day %></td>
                      <td><%= u.page %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </details>
        <% } %>
      </section>
    <% } %>

    <form method="post" action="/admin/schedule/create" class="card form-grid">
      <div class="full search-box">
        <label for="series_search">Cari Series *</label>
        <input id="series_search" type="text" placeholder="Ketik judul anime/donghua..." autocomplete="off" required />
        <input id="series_id" name="series_id" type="hidden" required />
        <div class="inline-actions" style="margin-top:8px;">
          <select id="series_filter_origin">
            <option value="">All Origin</option>
            <% filterOptions.origin.forEach((x) => { %>
              <option value="<%= x %>" <%= selectedOrigin === x ? 'selected' : '' %>><%= x %></option>
            <% }); %>
          </select>
          <select id="series_filter_platform">
            <option value="">All Platform</option>
            <% filterOptions.platform.forEach((x) => { %>
              <option value="<%= x %>" <%= selectedPlatform === x ? 'selected' : '' %>><%= x %></option>
            <% }); %>
          </select>
          <select id="series_filter_type">
            <option value="">All Type</option>
            <% filterOptions.type.forEach((x) => { %>
              <option value="<%= x %>" <%= selectedType === x ? 'selected' : '' %>><%= x %></option>
            <% }); %>
          </select>
          <button type="button" id="quick_donghua" class="btn ghost">Only Donghua</button>
        </div>
        <div id="series_pick_info" class="muted mono"></div>
        <div id="series_results" class="search-results"></div>
      </div>
      <div>
        <label for="day_of_week">Hari *</label>
        <select id="day_of_week" name="day_of_week" required>
          <% days.forEach((d) => { %>
            <option value="<%= d %>"><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label for="time_label">Jam (opsional)</label>
        <input id="time_label" name="time_label" placeholder="19:30 WIB" />
      </div>
      <div>
        <label for="sort_order">Urutan</label>
        <input id="sort_order" name="sort_order" type="number" min="0" value="0" />
      </div>
      <div>
        <label for="is_active">Aktif</label>
        <select id="is_active" name="is_active">
          <option value="1" selected>Ya</option>
          <option value="0">Tidak</option>
        </select>
      </div>
      <div class="full inline-actions">
        <button type="submit" class="btn">+ Tambah Jadwal</button>
      </div>
    </form>

    <section class="card">
      <div class="section-head">
        <h3>Daftar Jadwal</h3>
        <div class="inline-actions">
          <form method="post" action="/admin/schedule/auto-sync-otakudesu" class="inline-actions">
            <input type="number" name="page_start" min="1" max="30" value="1" style="width:90px" />
            <input type="number" name="page_end" min="1" max="30" value="5" style="width:90px" />
            <button type="submit" class="btn">Preview Sync Otakudesu</button>
          </form>
          <form method="get" action="/admin/schedule" class="inline-actions">
            <select name="day">
              <option value="">Semua Hari</option>
              <% days.forEach((d) => { %>
                <option value="<%= d %>" <%= selectedDay === d ? 'selected' : '' %>><%= d %></option>
              <% }); %>
            </select>
            <select name="origin">
              <option value="">All Origin</option>
              <% filterOptions.origin.forEach((x) => { %>
                <option value="<%= x %>" <%= selectedOrigin === x ? 'selected' : '' %>><%= x %></option>
              <% }); %>
            </select>
            <select name="platform">
              <option value="">All Platform</option>
              <% filterOptions.platform.forEach((x) => { %>
                <option value="<%= x %>" <%= selectedPlatform === x ? 'selected' : '' %>><%= x %></option>
              <% }); %>
            </select>
            <select name="type">
              <option value="">All Type</option>
              <% filterOptions.type.forEach((x) => { %>
                <option value="<%= x %>" <%= selectedType === x ? 'selected' : '' %>><%= x %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn ghost">Filter</button>
            <a class="btn ghost" href="/admin/schedule?origin=donghua">Quick Donghua</a>
            <a class="btn ghost" href="/admin/schedule">Reset</a>
          </form>
          <form method="post" action="/admin/schedule/delete-all" onsubmit="return confirm('Yakin hapus SEMUA daftar jadwal?');">
            <button type="submit" class="btn danger">Delete All Jadwal</button>
          </form>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Hari</th>
              <th>Jam</th>
              <th>Urutan</th>
              <th>Series</th>
              <th>Origin / Type</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((r) => { %>
              <tr>
                <td class="mono"><%= r.id %></td>
                <td><%= r.day_of_week %></td>
                <td><%= r.time_label || '-' %></td>
                <td><%= r.sort_order %></td>
                <td>
                  <a href="/admin/series/<%= r.series_id %>"><%= r.title %></a>
                  <span class="muted mono">(#<%= r.series_id %> / <%= r.series_slug %>)</span>
                </td>
                <td class="mono"><%= r.content_origin || '-' %> / <%= r.type || '-' %></td>
                <td><%= Number(r.is_active) === 1 ? 'Aktif' : 'Nonaktif' %></td>
                <td>
                  <div class="action-row">
                    <a class="btn ghost" href="/admin/schedule/<%= r.id %>/edit">Edit</a>
                    <form method="post" action="/admin/schedule/<%= r.id %>/delete" onsubmit="return confirm('Hapus jadwal ini?')">
                      <button type="submit" class="btn danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
            <% if (!rows.length) { %>
              <tr><td colspan="8" class="muted">Belum ada jadwal.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
  <script>
    (() => {
      const searchInput = document.getElementById('series_search');
      const seriesIdInput = document.getElementById('series_id');
      const resultsEl = document.getElementById('series_results');
      const infoEl = document.getElementById('series_pick_info');
      const filterOriginEl = document.getElementById('series_filter_origin');
      const filterPlatformEl = document.getElementById('series_filter_platform');
      const filterTypeEl = document.getElementById('series_filter_type');
      const quickDonghuaBtn = document.getElementById('quick_donghua');
      let timer = null;

      const escapeHtml = (str) =>
        String(str)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const clearResults = () => {
        resultsEl.innerHTML = '';
      };

      const pickSeries = (item) => {
        seriesIdInput.value = item.id;
        searchInput.value = item.title;
        infoEl.textContent = `Selected: #${item.id} / ${item.source_platform} / ${item.content_origin || '-'} / ${item.type || '-'} / ${item.series_slug}`;
        clearResults();
      };

      if (quickDonghuaBtn) {
        quickDonghuaBtn.addEventListener('click', () => {
          if (filterOriginEl) filterOriginEl.value = 'donghua';
          searchInput.focus();
        });
      }

      searchInput.addEventListener('input', () => {
        const q = searchInput.value.trim();
        seriesIdInput.value = '';
        infoEl.textContent = '';
        if (timer) clearTimeout(timer);
        if (q.length < 2) {
          clearResults();
          return;
        }

        timer = setTimeout(async () => {
          try {
            const origin = filterOriginEl ? filterOriginEl.value.trim() : '';
            const platform = filterPlatformEl ? filterPlatformEl.value.trim() : '';
            const type = filterTypeEl ? filterTypeEl.value.trim() : '';
            const params = new URLSearchParams({ q });
            if (origin) params.set('origin', origin);
            if (platform) params.set('platform', platform);
            if (type) params.set('type', type);

            const res = await fetch(`/admin/schedule/series-search?${params.toString()}`);
            const data = await res.json();
            const rows = Array.isArray(data.data) ? data.data : [];
            if (!rows.length) {
              resultsEl.innerHTML = '<div class="search-item muted">Tidak ada hasil</div>';
              return;
            }
            resultsEl.innerHTML = rows
              .map((item) => `<button type="button" class="search-item" data-id="${item.id}" data-title="${escapeHtml(item.title)}" data-slug="${escapeHtml(item.series_slug)}" data-platform="${escapeHtml(item.source_platform)}" data-origin="${escapeHtml(item.content_origin || '')}" data-type="${escapeHtml(item.type || '')}">#${item.id} - ${escapeHtml(item.title)} <span class="muted mono">(${escapeHtml(item.source_platform)} / ${escapeHtml(item.content_origin || '-')} / ${escapeHtml(item.type || '-')} / ${escapeHtml(item.series_slug)})</span></button>`)
              .join('');

            resultsEl.querySelectorAll('.search-item').forEach((btn) => {
              btn.addEventListener('click', () => {
                pickSeries({
                  id: btn.getAttribute('data-id'),
                  title: btn.getAttribute('data-title'),
                  series_slug: btn.getAttribute('data-slug'),
                  source_platform: btn.getAttribute('data-platform'),
                  content_origin: btn.getAttribute('data-origin'),
                  type: btn.getAttribute('data-type')
                });
              });
            });
          } catch (err) {
            resultsEl.innerHTML = '<div class="search-item muted">Gagal ambil data</div>';
          }
        }, 220);
      });
    })();
  </script>
</body>
</html>
