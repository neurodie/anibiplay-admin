<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule" class="active">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/notifications/send">Push Notif</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/users/premium">Manage Premium</a>
        <a href="/admin/leaderboard-xp">Leaderboard XP</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <p><a class="inline-link" href="/admin/schedule">&larr; Back to Schedule</a></p>

    <section class="hero card">
      <h1>Edit Jadwal #<%= row.id %></h1>
      <p class="muted">Series: <strong><%= row.title %></strong> (#<%= row.series_id %> / <%= row.source_platform %>)</p>
    </section>

    <% if (error) { %><p class="alert"><%= error %></p><% } %>

    <form method="post" action="/admin/schedule/<%= row.id %>/edit" class="card form-grid">
      <div class="full search-box">
        <label for="series_search">Cari Series *</label>
        <input id="series_search" type="text" value="<%= row.title %>" placeholder="Ketik judul anime/donghua..." autocomplete="off" required />
        <input id="series_id" name="series_id" type="hidden" value="<%= row.series_id %>" required />
        <div id="series_pick_info" class="muted mono">Selected: #<%= row.series_id %> / <%= row.source_platform %> / <%= row.series_slug %></div>
        <div id="series_results" class="search-results"></div>
      </div>
      <div>
        <label for="day_of_week">Hari *</label>
        <select id="day_of_week" name="day_of_week" required>
          <% days.forEach((d) => { %>
            <option value="<%= d %>" <%= row.day_of_week === d ? 'selected' : '' %>><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label for="time_label">Jam</label>
        <input id="time_label" name="time_label" value="<%= row.time_label || '' %>" />
      </div>
      <div>
        <label for="sort_order">Urutan</label>
        <input id="sort_order" name="sort_order" type="number" min="0" value="<%= row.sort_order %>" />
      </div>
      <div>
        <label for="is_active">Aktif</label>
        <select id="is_active" name="is_active">
          <option value="1" <%= Number(row.is_active) === 1 ? 'selected' : '' %>>Ya</option>
          <option value="0" <%= Number(row.is_active) === 0 ? 'selected' : '' %>>Tidak</option>
        </select>
      </div>
      <div class="full inline-actions">
        <button type="submit" class="btn">Save</button>
        <a class="btn ghost" href="/admin/schedule">Cancel</a>
      </div>
    </form>
  </main>
  <script>
    (() => {
      const searchInput = document.getElementById('series_search');
      const seriesIdInput = document.getElementById('series_id');
      const resultsEl = document.getElementById('series_results');
      const infoEl = document.getElementById('series_pick_info');
      let timer = null;

      const escapeHtml = (str) =>
        String(str)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');

      const clearResults = () => {
        resultsEl.innerHTML = '';
      };

      const pickSeries = (item) => {
        seriesIdInput.value = item.id;
        searchInput.value = item.title;
        infoEl.textContent = `Selected: #${item.id} / ${item.source_platform} / ${item.series_slug}`;
        clearResults();
      };

      searchInput.addEventListener('input', () => {
        const q = searchInput.value.trim();
        if (timer) clearTimeout(timer);
        if (q.length < 2) {
          clearResults();
          return;
        }

        timer = setTimeout(async () => {
          try {
            const res = await fetch(`/admin/schedule/series-search?q=${encodeURIComponent(q)}`);
            const data = await res.json();
            const rows = Array.isArray(data.data) ? data.data : [];
            if (!rows.length) {
              resultsEl.innerHTML = '<div class="search-item muted">Tidak ada hasil</div>';
              return;
            }
            resultsEl.innerHTML = rows
              .map((item) => `<button type="button" class="search-item" data-id="${item.id}" data-title="${escapeHtml(item.title)}" data-slug="${escapeHtml(item.series_slug)}" data-platform="${escapeHtml(item.source_platform)}">#${item.id} - ${escapeHtml(item.title)} <span class="muted mono">(${escapeHtml(item.source_platform)} / ${escapeHtml(item.series_slug)})</span></button>`)
              .join('');

            resultsEl.querySelectorAll('.search-item').forEach((btn) => {
              btn.addEventListener('click', () => {
                pickSeries({
                  id: btn.getAttribute('data-id'),
                  title: btn.getAttribute('data-title'),
                  series_slug: btn.getAttribute('data-slug'),
                  source_platform: btn.getAttribute('data-platform')
                });
              });
            });
          } catch (err) {
            resultsEl.innerHTML = '<div class="search-item muted">Gagal ambil data</div>';
          }
        }, 220);
      });
    })();
  </script>
</body>
</html>
