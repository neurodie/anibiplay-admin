<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series" class="active">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <p><a class="inline-link" href="/admin/episodes/<%= episode.id %>/streams">&larr; Back to Episode Streams</a></p>

    <section class="hero card">
      <h1>Create Stream</h1>
      <p class="muted">Series: <strong><%= episode.series_title %></strong> | Episode Slug: <span class="mono"><%= episode.chapter_slug %></span></p>
    </section>

    <% if (error) { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <form method="post" action="/admin/episodes/<%= episode.id %>/streams/create" class="card form-grid">
      <div>
        <label for="resolution">Resolution *</label>
        <input id="resolution" name="resolution" required placeholder="480p / 720p / 1080p" />
      </div>

      <div>
        <label for="stream_source_id">Stream Source ID</label>
        <input id="stream_source_id" name="stream_source_id" type="number" min="1" placeholder="opsional" />
      </div>

      <div>
        <label for="size_kb">Size KB</label>
        <input id="size_kb" name="size_kb" type="number" min="0" placeholder="opsional" />
      </div>

      <div class="full">
        <label for="stream_url">Stream URL *</label>
        <input id="stream_url" name="stream_url" required placeholder="https://..." />
      </div>

      <div class="full inline-actions">
        <button type="submit" class="btn">Create Stream</button>
        <a class="btn ghost" href="/admin/episodes/<%= episode.id %>/streams">Cancel</a>
      </div>
    </form>
  </main>
</body>
</html>
