<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series" class="active">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <p><a class="inline-link" href="/admin/series/<%= episode.series_id %>">&larr; Back to Series Detail</a></p>

    <% if (success) { %>
      <p class="alert ok"><%= success %></p>
    <% } %>
    <% if (error) { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <section class="hero card">
      <h1>Episode Streams</h1>
      <p class="muted">Series: <strong><%= episode.series_title %></strong></p>
      <p class="muted mono">Episode ID: <%= episode.id %> | Source Episode ID: <%= episode.source_episode_id %> | Slug: <%= episode.chapter_slug %></p>
      <div class="inline-actions">
        <a class="btn ghost" href="/admin/episodes/<%= episode.id %>/edit">Edit Episode</a>
        <a class="btn" href="/admin/episodes/<%= episode.id %>/streams/create">+ Add Stream</a>
      </div>
    </section>

    <section class="card">
      <h3>Stream List</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Resolution</th>
              <th>Stream Source ID</th>
              <th>Size KB</th>
              <th>URL</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% streams.forEach((s) => { %>
              <tr>
                <td class="mono"><%= s.id %></td>
                <td><span class="chip"><%= s.resolution || '-' %></span></td>
                <td class="mono"><%= s.stream_source_id === null ? 'null' : s.stream_source_id %></td>
                <td class="mono"><%= s.size_kb === null ? '-' : s.size_kb %></td>
                <td>
                  <% if (s.stream_url) { %>
                    <a href="<%= s.stream_url %>" target="_blank" rel="noreferrer" class="mono"><%= s.stream_url %></a>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td class="mono"><%= s.created_at %></td>
                <td>
                  <form method="post" action="/admin/streams/<%= s.id %>/delete" onsubmit="return confirm('Hapus stream ini?')">
                    <button type="submit" class="btn danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }); %>
            <% if (!streams.length) { %>
              <tr>
                <td colspan="7" class="muted">Tidak ada stream untuk episode ini.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
