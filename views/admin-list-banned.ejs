<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/notifications/send">Push Notif</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned" class="active">List Banned</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/users/premium">Manage Premium</a>
        <a href="/admin/leaderboard-xp">Leaderboard XP</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <section class="hero card">
      <h1>List Banned</h1>
      <p class="muted">Data ban user/device dari database user.</p>
    </section>

    <% if (revoked) { %>
      <p class="alert ok">Ban berhasil di-revoke.</p>
    <% } %>
    <% if (added) { %>
      <p class="alert ok">Ban baru berhasil ditambahkan.</p>
    <% } %>
    <% if (error) { %>
      <p class="alert"><%= error %></p>
    <% } %>

    <% if (tableMissing) { %>
      <section class="card">
        <p class="muted">Table <span class="mono">list_banned</span> tidak ditemukan di user DB.</p>
      </section>
    <% } else { %>
      <form method="post" action="/admin/list-banned/add" class="card form-grid">
        <h3>Add Banned User</h3>
        <input type="hidden" name="page" value="<%= page %>" />
        <input type="hidden" name="q" value="<%= q %>" />
        <input type="hidden" name="status" value="<%= status %>" />

        <div>
          <label for="user_id">User ID *</label>
          <div class="inline-actions">
            <input id="user_id" name="user_id" type="number" min="1" required />
            <button id="btn_find_device" type="button" class="btn ghost">Find Device</button>
          </div>
        </div>
        <div>
          <label for="device_id">Device ID</label>
          <input id="device_id" name="device_id" placeholder="andr-aacb75b32b9eeb51" />
          <p id="device_hint" class="muted"></p>
        </div>
        <div class="full">
          <label for="reason">Reason *</label>
          <textarea id="reason" name="reason" rows="2" required placeholder="Terlalu banyak request ke aplikasi"></textarea>
        </div>
        <div>
          <label for="banned_by">Banned By</label>
          <input id="banned_by" name="banned_by" type="number" min="1" placeholder="opsional: user_id admin" />
        </div>
        <div>
          <label for="expires_at">Expires At</label>
          <input id="expires_at" name="expires_at" type="datetime-local" />
          <p class="muted">Kosongkan untuk ban permanen.</p>
        </div>
        <div class="full inline-actions">
          <button type="submit" class="btn">Add Ban</button>
        </div>
      </form>

      <form method="get" action="/admin/list-banned" class="card filters-advanced">
        <div>
          <label for="q">Search</label>
          <input id="q" name="q" value="<%= q %>" placeholder="user_id, device_id, reason, banned_by" />
        </div>
        <div>
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="" <%= status === '' ? 'selected' : '' %>>All</option>
            <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="expired" <%= status === 'expired' ? 'selected' : '' %>>Expired</option>
            <option value="revoked" <%= status === 'revoked' ? 'selected' : '' %>>Revoked</option>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn">Apply Filter</button>
          <a href="/admin/list-banned" class="btn ghost">Reset</a>
        </div>
      </form>

      <section class="card">
        <div class="section-head">
          <p class="muted mono">Total: <%= Number(total).toLocaleString('id-ID') %> | Page <%= page %>/<%= totalPages %></p>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>User ID</th>
                <th>Device ID</th>
                <th>Reason</th>
                <th>Banned By</th>
                <th>Expires</th>
                <th>Revoked</th>
                <th>Created</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% rows.forEach((r) => { %>
                <tr>
                  <td class="mono"><%= r.id %></td>
                  <td class="mono"><%= r.user_id %></td>
                  <td class="mono"><%= r.device_id || '-' %></td>
                  <td><%= r.reason || '-' %></td>
                  <td><%= r.banned_by || '-' %></td>
                  <td class="mono"><%= r.expires_at_text || '-' %></td>
                  <td class="mono"><%= r.revoked_at_text || '-' %></td>
                  <td class="mono"><%= r.created_at_text || '-' %></td>
                  <td>
                    <% if (r.status_kind === 'active') { %>
                      <form method="post" action="/admin/list-banned/<%= r.id %>/revoke?page=<%= page %>&q=<%= encodeURIComponent(q) %>&status=<%= encodeURIComponent(status) %>" onsubmit="return confirm('Revoke ban ini?');">
                        <button type="submit" class="btn ghost">Revoke</button>
                      </form>
                    <% } else if (r.status_kind === 'expired') { %>
                      <span class="chip">Expired</span>
                    <% } else { %>
                      <span class="chip">Revoked</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
              <% if (!rows.length) { %>
                <tr>
                  <td colspan="9" class="muted">Tidak ada data untuk filter ini.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="pager">
          <% if (page > 1) { %>
            <a class="btn ghost" href="/admin/list-banned?page=<%= page - 1 %>&q=<%= encodeURIComponent(q) %>&status=<%= encodeURIComponent(status) %>">Prev</a>
          <% } %>
          <% if (page < totalPages) { %>
            <a class="btn ghost" href="/admin/list-banned?page=<%= page + 1 %>&q=<%= encodeURIComponent(q) %>&status=<%= encodeURIComponent(status) %>">Next</a>
          <% } %>
        </div>
      </section>
    <% } %>
  </main>
  <script>
    (function () {
      var userIdEl = document.getElementById('user_id');
      var deviceIdEl = document.getElementById('device_id');
      var findBtn = document.getElementById('btn_find_device');
      var hintEl = document.getElementById('device_hint');
      if (!userIdEl || !deviceIdEl || !findBtn || !hintEl) return;

      async function findDeviceByUserId() {
        var userId = String(userIdEl.value || '').trim();
        if (!userId) {
          hintEl.textContent = 'Isi user_id dulu.';
          return;
        }
        hintEl.textContent = 'Mencari device_id...';
        findBtn.disabled = true;
        try {
          var resp = await fetch('/admin/list-banned/device-suggest?user_id=' + encodeURIComponent(userId), {
            credentials: 'same-origin'
          });
          var json = await resp.json();
          if (!resp.ok || !json || !json.ok) {
            hintEl.textContent = (json && json.error) ? String(json.error) : 'Device tidak ditemukan';
            return;
          }
          if (json.device_id) {
            deviceIdEl.value = String(json.device_id);
            var src = json.source ? (' [source: ' + json.source + ']') : '';
            if (Array.isArray(json.suggestions) && json.suggestions.length > 1) {
              hintEl.textContent = 'Device terisi otomatis' + src + '. Alternatif: ' + json.suggestions.slice(1, 3).join(', ');
            } else {
              hintEl.textContent = 'Device terisi otomatis' + src + '.';
            }
          } else {
            hintEl.textContent = 'Belum ada device_id tersimpan untuk user ini.';
          }
        } catch (err) {
          hintEl.textContent = err && err.message ? err.message : 'Gagal mencari device_id';
        } finally {
          findBtn.disabled = false;
        }
      }

      findBtn.addEventListener('click', findDeviceByUserId);
      userIdEl.addEventListener('blur', function () {
        if (!String(deviceIdEl.value || '').trim()) findDeviceByUserId();
      });
    })();
  </script>
</body>
</html>
