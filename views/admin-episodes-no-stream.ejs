<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <strong>AnimeKita Panel</strong>
        <span>Admin</span>
      </div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series" class="active">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
      </nav>
      <form method="post" action="/admin/logout">
        <button type="submit" class="btn ghost">Logout</button>
      </form>
    </div>
  </header>

  <main class="container">
    <section class="hero card">
      <h1>Episodes Without Stream</h1>
      <p class="muted">Daftar episode yang belum punya link stream.</p>
    </section>

    <form method="get" action="/admin/episodes/no-stream" class="card filters-advanced">
      <div>
        <label for="q">Search</label>
        <input id="q" name="q" value="<%= q %>" placeholder="Series title atau chapter slug" />
      </div>
      <div>
        <label for="source_platform">Platform</label>
        <select id="source_platform" name="source_platform">
          <option value="">All Platform</option>
          <% platformOptions.forEach((p) => { %>
            <option value="<%= p %>" <%= platform === p ? 'selected' : '' %>><%= p %></option>
          <% }); %>
        </select>
      </div>
      <div class="filter-actions">
        <button type="submit" class="btn">Apply Filter</button>
        <a href="/admin/episodes/no-stream" class="btn ghost">Reset</a>
      </div>
    </form>

    <section class="card">
      <div class="section-head">
        <p class="muted mono">Total: <%= Number(total).toLocaleString('id-ID') %> | Page <%= page %>/<%= totalPages %></p>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Episode ID</th>
              <th>Series</th>
              <th>Platform</th>
              <th>Source Episode ID</th>
              <th>Chapter</th>
              <th>Slug</th>
              <th>Release Date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((e) => { %>
              <tr>
                <td class="mono"><%= e.id %></td>
                <td><a href="/admin/series/<%= e.series_id %>"><%= e.series_title %></a></td>
                <td><span class="chip"><%= e.series_platform || e.source_platform || '-' %></span></td>
                <td class="mono"><%= e.source_episode_id %></td>
                <td><%= e.chapter_label || '-' %></td>
                <td class="mono"><%= e.chapter_slug || '-' %></td>
                <td><%= e.release_date_text || '-' %></td>
                <td>
                  <a class="btn ghost" href="/admin/episodes/<%= e.id %>/streams">Manage Stream</a>
                </td>
              </tr>
            <% }); %>
            <% if (!rows.length) { %>
              <tr>
                <td colspan="8" class="muted">Tidak ada episode tanpa stream untuk filter ini.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="pager">
        <% if (page > 1) { %>
          <a class="btn ghost" href="/admin/episodes/no-stream?page=<%= page - 1 %>&q=<%= encodeURIComponent(q) %>&source_platform=<%= encodeURIComponent(platform) %>">Prev</a>
        <% } %>
        <% if (page < totalPages) { %>
          <a class="btn ghost" href="/admin/episodes/no-stream?page=<%= page + 1 %>&q=<%= encodeURIComponent(q) %>&source_platform=<%= encodeURIComponent(platform) %>">Next</a>
        <% } %>
      </div>
    </section>
  </main>
</body>
</html>
