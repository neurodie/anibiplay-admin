<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/public/admin.css" />
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand"><strong>AnimeKita Panel</strong><span>Admin</span></div>
      <nav>
        <a href="/admin">Dashboard</a>
        <a href="/admin/series" class="active">Series</a>
        <a href="/admin/topanime">Top Anime</a>
        <a href="/admin/schedule">Schedule</a>
        <a href="/admin/updater">Updater</a>
        <a href="/admin/announcement">Announcement</a>
        <a href="/admin/notifications/send">Push Notif</a>
        <a href="/admin/episode-error-reports">Error Reports</a>
        <a href="/admin/list-banned">List Banned</a>
        <a href="/admin/users">Users</a>
        <a href="/admin/users/premium">Manage Premium</a>
        <a href="/admin/leaderboard-xp">Leaderboard XP</a>
      </nav>
      <form method="post" action="/admin/logout"><button type="submit" class="btn ghost">Logout</button></form>
    </div>
  </header>
  <main class="container">
    <p><a class="inline-link" href="/admin/series">&larr; Back to Series</a></p>
    <section class="hero card">
      <h1>Import All-in-One JSON</h1>
      <p class="muted">Satu payload untuk batch series, episodes, dan streams sekaligus.</p>
    </section>
    <% if (error) { %><p class="alert"><%= error %></p><% } %>
    <% if (result) { %>
      <section class="card">
        <h3>Import Result</h3>
        <div class="detail-grid">
          <div><strong>Series:</strong> total <%= result.series.total %> | inserted <%= result.series.inserted %> | dup <%= result.series.skipped_duplicate %> | failed <%= result.series.failed %></div>
          <div><strong>Episodes:</strong> total <%= result.episodes.total %> | inserted <%= result.episodes.inserted %> | dup <%= result.episodes.skipped_duplicate %> | failed <%= result.episodes.failed %></div>
          <div><strong>Streams:</strong> total <%= result.streams.total %> | inserted <%= result.streams.inserted %> | dup <%= result.streams.skipped_duplicate %> | failed <%= result.streams.failed %></div>
        </div>
        <% if (result.errors && result.errors.length) { %>
          <p class="muted" style="margin-top:10px;"><strong>Errors (max 30):</strong></p>
          <ul class="metric-list">
            <% result.errors.slice(0, 30).forEach((e) => { %>
              <li><span class="mono"><%= e %></span></li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    <% } %>
    <section class="card">
      <h3>Sample JSON</h3>
      <pre class="mono" style="white-space:pre-wrap; background:#f3f8f4; border:1px solid #e3ebe4; padding:10px; border-radius:10px;">{
  "series": [
    {
      "source_platform": "donghub",
      "source_series_id": 605,
      "content_origin": "anime",
      "title": "Black Clover",
      "title2": "Black Clover (TV)",
      "series_slug": "black-clover",
      "cover_url": "https://cdn.example.com/black-clover.jpg",
      "type": "TV",
      "status": "Completed",
      "rating": 8.1,
      "published_text": "Oct 3, 2017",
      "author": "Studio Pierrot",
      "synopsis": "Asta dan Yuno berjuang menjadi Kaisar Sihir.",
      "genres": ["Action", "Comedy", "Fantasy", "Shounen"]
    }
  ],
  "episodes": [
    {
      "source_platform": "donghub",
      "source_episode_id": 15528,
      "series_slug": "black-clover",
      "chapter_label": "01",
      "chapter_slug": "al-605-1",
      "release_date_text": "3 Oktober, 2017"
    }
  ],
  "streams": [
    {
      "chapter_slug": "al-605-1",
      "resolution": "1080p",
      "stream_source_id": 999111,
      "stream_url": "https://cdn.example.com/black-clover/ep1-1080p.mp4",
      "size_kb": 401204
    },
    {
      "chapter_slug": "al-605-1",
      "resolution": "720p",
      "stream_url": "https://cdn.example.com/black-clover/ep1-720p.mp4",
      "size_kb": 203455
    }
  ]
}</pre>
      <p class="muted" style="margin-top:8px;">Wajib (series): <span class="mono">source_platform, source_series_id, content_origin, title, series_slug</span>. <span class="mono">title2</span> opsional.</p>
      <p class="muted">Wajib (episodes): <span class="mono">source_platform, source_episode_id, series_slug, chapter_slug</span>.</p>
      <p class="muted">Wajib (streams): <span class="mono">chapter_slug, resolution, stream_url</span>.</p>
      <p class="muted" style="margin-top:8px;">Mode aman: episode wajib resolve pakai <span class="mono">source_platform + series_slug</span>.</p>
      <p class="muted">Mode aman: stream wajib resolve pakai <span class="mono">chapter_slug</span>.</p>
    </section>
    <form method="post" action="/admin/import-json-all" class="card">
      <label for="json_file">Load from .json file</label>
      <input id="json_file" type="file" accept="application/json,.json" />
      <label for="json_payload" style="margin-top:10px;">JSON Payload *</label>
      <textarea id="json_payload" name="json_payload" rows="24" required class="mono"><%= payloadText || '' %></textarea>
      <div class="inline-actions" style="margin-top:10px;">
        <button type="submit" class="btn">Import All</button>
        <a class="btn ghost" href="/admin/import-json-all">Reset</a>
      </div>
    </form>
  </main>
  <script>
    (function () {
      var fileInput = document.getElementById('json_file');
      var textarea = document.getElementById('json_payload');
      if (!fileInput || !textarea) return;
      fileInput.addEventListener('change', function () {
        var file = fileInput.files && fileInput.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function () {
          textarea.value = String(reader.result || '');
        };
        reader.readAsText(file);
      });
    })();
  </script>
</body>
</html>
